{
	"name": "vike-content-collection",
	"version": "0.0.1",
	"description": "Content collection plugin for Vike + Vite with zod schema validation",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./config": {
			"types": "./dist/config.d.ts",
			"default": "./dist/config.js"
		}
	},
	"typesVersions": {
		"*": {
			"config": [
				"./dist/config.d.ts"
			]
		}
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --fix .",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"gray-matter": "^4.0.3"
	},
	"peerDependencies": {
		"vike": ">=0.4.250",
		"vite": ">=6.0.0",
		"zod": ">=3.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.4.0",
		"typescript": "^5.7.0",
		"vike": "^0.4.250",
		"vite": "^6.0.0",
		"zod": "^3.24.0"
	},
	"license": "MIT",
	"keywords": [
		"vite-plugin",
		"vike",
		"content-collection",
		"markdown",
		"frontmatter",
		"zod"
	]
}
