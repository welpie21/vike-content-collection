{
	"name": "vike-content-collection",
	"version": "0.0.1",
	"description": "Content collection plugin for Vike + Vite with zod schema validation",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./config": {
			"types": "./dist/config.d.ts",
			"default": "./dist/config.js"
		}
	},
	"typesVersions": {
		"*": {
			"config": [
				"./dist/config.d.ts"
			]
		}
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --fix .",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"github-slugger": "^2.0.0",
		"gray-matter": "^4.0.3",
		"jiti": "^2.6.1",
		"mdast-util-to-string": "^4.0.0",
		"rehype-raw": "^7.0.0",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-mdx": "^3.1.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"smol-toml": "^1.6.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0"
	},
	"peerDependencies": {
		"@mdx-js/mdx": ">=3.0.0",
		"vike": ">=0.4.250",
		"vite": ">=7.0.0",
		"zod": ">=3.0.0"
	},
	"peerDependenciesMeta": {
		"@mdx-js/mdx": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@mdx-js/mdx": "^3.1.1",
		"@types/bun": "^1.3.10",
		"@types/github-slugger": "^1.3.0",
		"@types/mdast": "^4.0.4",
		"@types/node": "^25.4.0",
		"typescript": "^5.7.0",
		"vike": "^0.4.250",
		"vite": "^7.0.0",
		"zod": "^3.24.0"
	},
	"license": "MIT",
	"keywords": [
		"vite-plugin",
		"vike",
		"content-collection",
		"markdown",
		"frontmatter",
		"zod"
	]
}
